DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventrent"
# In Vercel with Supabase integration, DATABASE_POSTGRES_URL can be used instead.
# Optional tuning for serverless Postgres connections:
# PG_POOL_MAX="1"
# PG_IDLE_TIMEOUT_MS="5000"
# PG_CONNECT_TIMEOUT_MS="10000"
# Set this only if you explicitly need Supabase session pooler on port 5432:
# SUPABASE_KEEP_SESSION_POOLER="true"
AUTH_SECRET="change-me-in-production"
